<UserControl
    x:Class="SystemWpf.Views.Main"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SystemWpf.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:SystemWpf.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Storyboard x:Key="FlowAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="GlowBorder"
                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(TranslateTransform.X)"
                From="-1"
                To="1"
                Duration="0:0:3" />
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <Canvas x:Name="ParticleCanvas" IsHitTestVisible="False" />
        <!--  背景  -->
        <Border CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect
                    x:Name="GlowEffect"
                    BlurRadius="10"
                    Opacity="0.3"
                    ShadowDepth="0"
                    Color="#00FFFF" />
            </Border.Effect>
            <Border.Background>
                <LinearGradientBrush>
                    <GradientStop Offset="0" Color="#AA0A0F1F" />
                    <GradientStop Offset="1" Color="#66000000" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!--  流光边框  -->
        <Border
            x:Name="GlowBorder"
            BorderThickness="2"
            CornerRadius="20">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <LinearGradientBrush.RelativeTransform>
                        <TranslateTransform X="-1" />
                    </LinearGradientBrush.RelativeTransform>

                    <GradientStop Offset="0" Color="#00FFFF" />
                    <GradientStop Offset="0.5" Color="#FF00FF" />
                    <GradientStop Offset="1" Color="#00FFFF" />
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <!--  内容  -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock
                    Margin="20"
                    FontSize="18"
                    Foreground="White">
                    <Run Text="宿主：" />
                    <Run Text="{Binding Name, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Margin="20" Foreground="#99FFFFFF">
                    <Run Text="境界：" />
                    <Run Text="{Binding Level, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Margin="20" Foreground="White">
                    <Run Text="脂肪率：" />
                    <Run Foreground="Orange" Text="{Binding FatRate, Mode=OneWay}" />
                    <Run Foreground="Red" Text="%（异常）" />
                </TextBlock>
            </StackPanel>

            <TextBlock
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Foreground="Red"
                Text="● 异常">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation
                                    AutoReverse="True"
                                    Storyboard.TargetProperty="Opacity"
                                    From="1"
                                    To="0.2"
                                    Duration="0:0:0.8" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!--  音波  -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding WaveValues}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="4"
                            Height="{Binding}"
                            Margin="1"
                            Background="#00FFFF" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!--  按钮  -->
        <Button
            Margin="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Command="{Binding PlayCommand}"
            Content="系统播报" />

    </Grid>
</UserControl>
